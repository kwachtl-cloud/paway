rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      // Anyone authenticated can read user profiles (for SOS alerts, messaging)
      allow read: if isAuthenticated();
      
      // Only user can create their own profile
      allow create: if isAuthenticated() && isOwner(userId);
      
      // Only user can update/delete their own profile
      allow update, delete: if isAuthenticated() && isOwner(userId);
      
      // User's pets subcollection (NEW - user-scoped pets)
      match /pets/{petId} {
        // Anyone authenticated can read pets (for SOS alerts)
        allow read: if isAuthenticated();
        
        // Only pet owner can create/update/delete their pets
        allow create, update, delete: if isAuthenticated() && isOwner(userId);
      }
    }
    
    // ============================================
    // PETS COLLECTION - LEGACY (kept for backward compatibility)
    // ============================================
    match /pets/{petId} {
      // Anyone authenticated can read pet profiles (for SOS alerts)
      allow read: if isAuthenticated();
      
      // Any authenticated user can create a pet
      allow create: if isAuthenticated();
      
      // Only pet owner can update/delete
      allow update, delete: if isAuthenticated() && 
        resource.data.owner_uid == request.auth.uid;
    }
    
    // ============================================
    // SOS ALERTS - MVP Feature #1
    // ============================================
    match /sos_alerts/{alertId} {
      // All authenticated users can read SOS alerts (to help find lost pets)
      allow read: if isAuthenticated();
      
      // Any authenticated user can create an SOS alert
      allow create: if isAuthenticated();
      
      // Alert creator can update their own alert
      // Anyone can update status to 'resolved' (if they found the pet)
      allow update: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || 
         request.resource.data.status == 'resolved');
      
      // Only creator can delete
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // ============================================
    // PARK CHECK-INS - MVP Feature #2
    // ============================================
    match /park_checkins/{checkinId} {
      // All authenticated users can see who's at the park
      allow read: if isAuthenticated();
      
      // Any authenticated user can check in
      allow create: if isAuthenticated();
      
      // Only check-in creator can update/delete their check-in
      allow update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // ============================================
    // PET-FRIENDLY PLACES - MVP Feature #2
    // ============================================
    match /pet_places/{placeId} {
      // All authenticated users can read places
      allow read: if isAuthenticated();
      
      // Any authenticated user can add a place
      allow create: if isAuthenticated();
      
      // Place creator can update their own place
      allow update: if isAuthenticated() && 
        resource.data.addedBy == request.auth.uid;
      
      // Only admins can delete places (for now, no one can delete)
      allow delete: if false;
    }
    
    // ============================================
    // MESSAGING - Conversations & Messages
    // ============================================
    match /conversations/{conversationId} {
      // Users can read conversations they're part of
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participantIds;
      
      // Users can create conversations
      allow create: if isAuthenticated() && 
        request.auth.uid in request.resource.data.participantIds;
      
      // Participants can update conversation metadata
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participantIds;
      
      // No one can delete conversations
      allow delete: if false;
      
      // Messages subcollection
      match /messages/{messageId} {
        // Users can read messages from their conversations
        allow read: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        
        // Users can send messages to their conversations
        allow create: if isAuthenticated() && 
          request.auth.uid == request.resource.data.senderId &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        
        // No updates or deletes for messages
        allow update, delete: if false;
      }
    }
    
    // ============================================
    // LEGACY COLLECTIONS (keep for backward compatibility)
    // ============================================
    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow write: if false; // Read-only for MVP
    }
    
    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow write: if false; // Disabled for MVP Phase 1
    }
    
    match /nearby_dogs/{dogId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // For testing
    }
  }
}
